# OpenRouter — demo Landing, Onboarding IA, HelpChat (misma clave)
# VITE_OPENROUTER_API_KEY=sk-or-v1-...

# Dominio público para enlaces legales en landing/login (default https://thekroneai.com)
# VITE_PUBLIC_SITE_URL=https://thekroneai.com

# Supabase (obligatorios)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Opcional — si ensureUserRow crea tu fila en users, este email recibe es_admin=true (propietario único)
# VITE_BOOTSTRAP_ADMIN_EMAIL=tu@email.com

# Stripe — recarga de créditos (solo la clave pública en el frontend)
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# n8n — URL base (usado en Credits, Integraciones CRM y demo Landing)
# Webhooks: create-checkout, stripe-payment, crm-incoming, demo-call, send-email (Resend)
VITE_N8N_URL=https://tu-instancia-n8n.example.com

# Resend (opcional en cliente): VITE_RESEND_API_KEY=re_[tu_nueva_key]
# Preferible: dejar Resend solo en n8n y usar VITE_N8N_URL + POST /webhook/send-email
# (body: to, subject, html, template, data). Si hay VITE_N8N_URL, el front no usa la API key.

# Logo.dev — logos de CRM en catálogo (Integraciones / Admin)
VITE_LOGODEV_TOKEN=pk_...

# Opcional — plantilla Google Sheets (Contactos)
# VITE_GOOGLE_SHEETS_TEMPLATE_URL=https://docs.google.com/spreadsheets/...

# La STRIPE_SECRET_KEY (sk_test_...) NUNCA va aquí: solo en n8n (servidor).
